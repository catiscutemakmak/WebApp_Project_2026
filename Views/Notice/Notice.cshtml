@model List<hateekub.DTOS.NotificationDTO>
@{
    ViewData["Title"] = "Notification -";
}

@section Styles {
    <link rel="stylesheet" href="~/css/notice.css" asp-append-version="true" />
}

<div id="NoticeContainer" class="NoticeContainer">
</div>

@section Scripts {
    <script>
        const notifications = @Html.Raw(Json.Serialize(Model ?? new List<hateekub.DTOS.NotificationDTO>()));
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/notice/mark-all-read', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(() => {
                // อัปเดต badge ให้เป็น 0
                const badge = document.getElementById('notificationBadge');
                if (badge) {
                    badge.style.display = 'none';
                }
            });
        });
        // ในหน้า Frontend เมื่อเจ้าของกดปุ่มเริ่มเกม
        fetch(`/game/${gameName}/StartGame/${roomId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                console.log('Game started!');
            }
        });
    </script>
    <script src="~/js/notice.js" asp-append-version="true"></script>
}