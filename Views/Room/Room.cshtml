    <div class="cyber-title">SYSTEM LOADING</div>

    <div class="cyber-progress">
      <div class="cyber-bar"></div>
    </div>

    <div class="cyber-text">Accessing room...</div>
  </div>
</div>

    <script>
    const gameName = "@ViewBag.GameName";
    const roomId = "@ViewBag.RoomId";
</script>


