@model List<hateekub.Models.RoomPlayer>
@{
ViewData["Title"] = "Match History";
Layout = "~/Views/Shared/_Layout.cshtml";
}

<head>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;500;700&family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/history.css">
</head>

<div class="history_page">

    <div class="header">
        <a href="javascript:history.back()" class="back-btn">
            <span class="icon">
                &#x2039;
            </span>
            <span class="text">BACK</span>
        </a>
    </div>

    <div>
        <h1 class="page-title">
            @(ViewBag.ProfileNickname != null ? ViewBag.ProfileNickname + "'s " : "")Match History
        </h1>
    </div>

    <div class="history-list">

        @if (Model == null || !Model.Any())
        {
            <p style="text-align:center; color:#888;">No history yet.</p>
        }
        else
        {
            foreach (var entry in Model)
            {
                <div class="history-card">
                    <div class="game-info">
                        <div class="game-details">
                            <h3>@entry.Room?.Game?.GameName</h3>
                            <span class="mode">@entry.Room?.GameMode</span>
                            <span class="date">@entry.Room?.PlayDateTime.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                    </div>

                    <div class="teammates">
                        @foreach (var player in (entry.Room?.Players
                            .Where(p => p.Status == hateekub.Models.PlayerStatus.Active || p.Status == hateekub.Models.PlayerStatus.Left)
                            .Take(5) ?? Enumerable.Empty<hateekub.Models.RoomPlayer>()))
                        {
                            <img src="@(string.IsNullOrEmpty(player.Avatar) ? "/images/profile/avatar-default.jpg" : player.Avatar)"
                                 class="avatar" title="@(player.User?.Nickname ?? player.User?.Username ?? "Unknown")">
                        }
                    </div>

                    <div class="action">
                        <a asp-controller="Match" asp-action="Room" asp-route-id="@entry.RoomId" class="view-btn">VIEW MORE</a>
                    </div>
                </div>
            }
        }

    </div>
</div>