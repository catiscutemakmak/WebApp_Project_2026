    <a asp-controller="Match"
    asp-action="Match"
    asp-route-gameName="@ViewBag.GameName"
    class="Backbtn">
         BACK
    </a>
    <div class="bottom-bar">
        <button id="Readybtn" class="Readybtn">
            Ready
        </button>

        <button id = "Startbtn"class="Startbtn">
            START
        </button>

        <button id= "Leavebtn" class="Leavebtn">
            LEAVE PARTY
        </button>

        <button id="kickbtn" class="kickbtn">🗑️</button>

    </div>




<div id="chatContainer" class="chatContainer"></div>

</div>
<div id="loadingOverlay" class="cyber-loading hide">
