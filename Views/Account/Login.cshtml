@model LoginViewModel
@{
    ViewData["HideNavbar"] = true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/css/loginpage.css">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Noto+Sans+Thai:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="particles"></div>
    <div class="particles">
    <span></span><span></span><span></span>
    <span></span><span></span><span></span>
    </div>
    <form asp-action="Login" method="post">
        <h2 class="title">Login</h2>
        <div class="whole-form">
            <div class="form-group">
                <label>Email Address</label>
                <input asp-for="Username"  placeholder="Enter your email address"/>
                <span asp-validation-for="Username" style="color:red; margin-top:5px;"></span>
            </div>
            <div class="form-group">
                <label>Password</label>
                <div class="password-container">
                    <input asp-for="Password" type="password" id="passwordInput" placeholder="Enter your password"/>
                    <span class="toggle-password" onclick="togglePasswordVisibility()">👀</span>
                </div>
                <span asp-validation-for="Password" style="color:red; margin-top:5px;"></span>
            </div>

            <div style="color:red; text-align:center; margin-top:10px;">
                @ViewBag.Error
            </div>
        </div>
        <button type="submit">LOGIN</button>

        <div class="register-link">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Register here</a>
        </div>

    </form>
    <script>
        function togglePasswordVisibility() {
            var passwordInput = document.getElementById('passwordInput');
            var toggleButton = document.querySelector('.toggle-password');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleButton.textContent = '🙈';
            } else {
                passwordInput.type = 'password';
                toggleButton.textContent = '👀';
            }
        }
    </script>
</body>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");     
    }
}