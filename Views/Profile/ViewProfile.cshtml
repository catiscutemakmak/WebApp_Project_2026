@model hateekub.Models.UserProfile
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@100;300;400;500;700&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="~/css/ViewProfile.css" />
</head>

<body>

    <div class="container">

        <!-- LEFT -->
        <div class="left-panel">
            <a asp-controller='Home' asp-action='Index' class="back-btn">
                <span class="icon">
                    &#x2039; <!-- ❮ -->
                </span>
                <span class="text">BACK</span>
            </a>

            <div class="avatar">
                <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath) 
                                                         ? "/images/profile/avatar-default.jpg"
                                                         : Model.ProfileImagePath)" alt="Profile Image" />
            </div>
            <h1 class="name-left">@(string.IsNullOrWhiteSpace(Model.Nickname) ? "User" : Model.Nickname)</h1>
            <a asp-controller="Profile" asp-action="EditProfile" class="edit-btn">
                <svg class="edit-icon" xmlns="http://www.w3.org/2000/svg" viewBox="-49.49 -49.49 593.92 593.92">
                    <path d="M389.844,182.85c-6.743,0-12.21,5.467-12.21,12.21v222.968c0,23.562-19.174,42.735-42.736,42.735H67.157
                    c-23.562,0-42.736-19.174-42.736-42.735V150.285c0-23.562,19.174-42.735,42.736-42.735h267.741
                    c6.743,0,12.21-5.467,12.21-12.21s-5.467-12.21-12.21-12.21H67.157C30.126,83.13,0,113.255,0,150.285v267.743
                    c0,37.029,30.126,67.155,67.157,67.155h267.741c37.03,0,67.156-30.126,67.156-67.155V195.061
                    C402.054,188.318,396.587,182.85,389.844,182.85z" />
                    <path d="M483.876,20.791c-14.72-14.72-38.669-14.714-53.377,0L221.352,229.944
                    c-0.28,0.28-3.434,3.559-4.251,5.396l-28.963,65.069c-2.057,4.619-1.056,10.027,2.521,13.6
                    c2.337,2.336,5.461,3.576,8.639,3.576c1.675,0,3.362-0.346,4.96-1.057l65.07-28.963
                    c1.83-0.815,5.114-3.97,5.396-4.25L483.876,74.169
                    c7.131-7.131,11.06-16.61,11.06-26.692C494.936,37.396,491.007,27.915,483.876,20.791z" />
                </svg>
                <span class="btn-text">EDIT</span>
            </a>

        </div>

        <!-- RIGHT -->
        <div class="right-panel">

            <!-- STATUS -->
            <div class="status-box">
                Hi! @(string.IsNullOrWhiteSpace(Model.Nickname) ? "User" : Model.Nickname)
            </div>

            <!-- RANK -->
            <section class="rank-section">
                <h3 class="rank-right">Rank</h3>
                <div class="rank-list">
                    @if (Model.ProfileGames != null && Model.ProfileGames.Any())
                    {
                        foreach (var game in Model.ProfileGames)
                        {
                            var gameKey = game.GameName.ToLower();

                            // รวมร่าง: กำหนดทั้งชื่อแสดงผล, Class และ Path ของรูปภาพ
                            var (displayName, imageClass, imageUrl) = gameKey switch
                            {
                                "valorant" => ("Valorant", "game-valorant", "/images/valorant.webp"),
                                "mlbb" => ("Mobile Legends Bang Bang", "game-mlbb", "/images/bg - mlbb.png"),
                                "csgo" => ("CS:GO", "game-csgo", "/images/csgo.jpg"),
                                "rov" => ("RoV", "game-rov", "/images/bg - rov.png"),
                                "overwatch" => ("Overwatch 2", "game-ow2", "/images/bg - ow2.png"),
                                "pubg" => ("PUBG: BATTLEGROUNDS", "game-pubg", "/images/bg - pubg.png"),
                                "amongus" => ("Among Us", "game-amongus", "/images/bg - among us.png"),
                                "lol" => ("League of Legends", "game-lol", "/images/lol_bg.avif"),
                            };

                            <div class="rank-card @imageClass"
                                 style="background-image: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('@imageUrl');">
                                <div class="game-name">@displayName</div>
                                <div class="rank-name">@game.Rank</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rank-card">
                            <span>No games added</span>
                        </div>
                    }
                </div>
            </section>

            <!-- HISTORY -->
            <section class="history-section">
                <h3>History</h3>
                <div class="history-card">
                    <div class="history-title">MLBB played as Support</div>
                    <div class="history-desc">
                        Your post "หาเล่นกดแรงค์ครับ ผมแบกได้ ตอนนี้"
                    </div>
                    <div class="history-footer">
                        <span class="score">2/5/15</span>
                        <span class="date">10-2-2026</span>
                    </div>
                </div>
            </section>

            <!-- REVIEW -->
            <div class="review-header">
                <h2>Review (@Model.Reviews.Count)</h2>
                @if (!ViewBag.IsOwnProfile)
                {
                    <a asp-controller="User" asp-action="Review" asp-route-id="@Model.Id" class="review-btn">
                        Write Review
                    </a>
                }
            </div>

            @if (!Model.Reviews.Any())
            {
                <div class="review-box">No reviews yet.</div>
            }
            else
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="review-box">
                        <div style="display:flex; justify-content:space-between">
                            <strong>@(review.Reviewer?.Username ?? "Unknown")</strong>
                            <span>
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <span>⭐</span>
                                }
                            </span>
                        </div>
                        <p>@review.Description</p>
                    </div>
                }
            }
            <form asp-controller="Account" asp-action="Logout" method="post" style="width: 100%; margin-top: 10px;">
                @Html.AntiForgeryToken() @* เพื่อความปลอดภัยป้องกัน CSRF *@
                <button type="submit" class="logout-btn">
                    <svg class="logout-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20"
                         height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round" style="margin-right: 8px;">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    <span class="btn-text">LOGOUT</span>
                </button>
            </form>

        </div>
    </div>

</body>

</html>