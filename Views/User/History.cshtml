@model List<hateekub.Models.RoomPlayer>
@{
ViewData["Title"] = "Match History";
Layout = "~/Views/Shared/_Layout.cshtml";
}

<head>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;500;700&family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/history.css">
</head>

<div class="history_page">

    <div class="header">
        <a asp-controller="Profile" asp-action="ViewProfile" asp-route-id="@ViewBag.ProfileId" class="back-btn">
            <span class="icon">
                &#x2039;
            </span>
            <span class="text">BACK</span>
        </a>
    </div>

    <div>
        <h1 class="page-title">
            @(ViewBag.ProfileNickname != null ? ViewBag.ProfileNickname + "'s " : "")Match History
        </h1>
    </div>

    <div class="history-list">

        @if (Model == null || !Model.Any())
        {
            <p style="text-align:center; color:#888;">No history yet.</p>
        }
        else
        {
            foreach (var entry in Model)
            {
                <div class="history-card">
                    <div class="game-info">
                        <div class="game-details">
                            <h3>@entry.Room?.Game?.GameName</h3>
                            <span class="mode">@entry.Room?.GameMode</span>
                            <span class="date">@entry.Room?.PlayDateTime.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                    </div>

                    <div class="teammates">
                        @foreach (var player in (entry.Room?.Players
                            .Where(p => p.Status == hateekub.Models.PlayerStatus.Active || p.Status == hateekub.Models.PlayerStatus.Left)
                            .Take(5) ?? Enumerable.Empty<hateekub.Models.RoomPlayer>()))
                        {
                            <img src="@(string.IsNullOrEmpty(player.Avatar) ? "/images/profile/avatar-default.jpg" : player.Avatar)"
                                 class="avatar" title="@(player.User?.Nickname ?? player.User?.Username ?? "Unknown")">
                        }
                    </div>

                    <div class="action">
                        <a asp-controller="Match" asp-action="Room" asp-route-id="@entry.RoomId" class="view-btn">VIEW MORE</a>
                    </div>
                </div>
            }
        }

    </div>
</div>

    <div>
        <h1 class="page-title">
            @(ViewBag.ProfileNickname != null ? ViewBag.ProfileNickname + "'s " : "")Match History
        </h1>
    </div>

    <div class="history-list">

        <div class="history-card">
            <div class="game-info">
                <div class="game-img"
                    style="background-image: url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRd7M80-F5f0jRzFfXo-3jZ9ZZ9Z9Z9Z9Z9Z9&s');">
                </div>
                <div class="game-details">
                    <h3>Valorant</h3>
                    <span class="mode">Ranked - 5v5</span>
                    <span class="date">20 Oct 2023, 14:30</span>
                </div>
            </div>

            <div class="teammates">
                <img src="https://i.pravatar.cc/100?img=1" class="avatar" title="User A">
                <img src="https://i.pravatar.cc/100?img=2" class="avatar" title="User B">
                <img src="https://i.pravatar.cc/100?img=3" class="avatar" title="User C">
                <img src="https://i.pravatar.cc/100?img=4" class="avatar" title="User D">
            </div>

            <div class="action">
                <a asp-controller="Match" asp-action="Room" class="view-btn">VIEW MORE</a>
            </div>
        </div>

        <div class="history-card">
            <div class="game-info">
                <div class="game-img"
                    style="background-image: url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRd7M80-F5f0jRzFfXo-3jZ9ZZ9Z9Z9Z9Z9Z9&s');">
                </div>
                <div class="game-details">
                    <h3>RoV</h3>
                    <span class="mode">Standard</span>
                    <span class="date">19 Oct 2023, 20:15</span>
                </div>
            </div>

            <div class="teammates">
                <img src="https://i.pravatar.cc/100?img=5" class="avatar">
                <img src="https://i.pravatar.cc/100?img=6" class="avatar">
                <img src="https://i.pravatar.cc/100?img=7" class="avatar">
                <img src="https://i.pravatar.cc/100?img=8" class="avatar">
            </div>

            <div class="action">
                <a asp-controller="Match" asp-action="Room" class="view-btn">VIEW MORE</a>
            </div>
        </div>

        <div class="history-card">
            <div class="game-info">
                <div class="game-img"
                    style="background-image: url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRd7M80-F5f0jRzFfXo-3jZ9ZZ9Z9Z9Z9Z9Z9&s');">
                </div>
                <div class="game-details">
                    <h3>Overwatch 2</h3>
                    <span class="mode">Quick Play</span>
                    <span class="date">18 Oct 2023, 10:00</span>
                </div>
            </div>

            <div class="teammates">
                <img src="https://i.pravatar.cc/100?img=10" class="avatar">
                <img src="https://i.pravatar.cc/100?img=11" class="avatar">
            </div>

            <div class="action">
                <a asp-controller="Match" asp-action="Room" class="view-btn">VIEW MORE</a>
            </div>
        </div>

    </div>
</div>